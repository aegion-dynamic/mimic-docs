<!DOCTYPE html>
<html lang="{{ language }}" class="sidebar-visible no-js">

<head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="{{ path_to_root }}theme/css/general.css">
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    {{{ head }}}
</head>

<body>
    <div id="container">
        <!-- Sidebar -->
        <nav id="sidebar" class="sidebar" aria-label="Table of contents">
            <div class="sidebar-header">
                <img src="{{ path_to_root }}logo.svg" alt="Logo">
            </div>
            <div class="sidebar-scrollbox">
                {{{ toc }}}
            </div>
        </nav>

        <!-- Main Content -->
        <main id="main">
            <div class="top-bar">
                <button id="sidebar-toggle" class="icon-button" aria-label="Toggle Table of Contents">
                    <span>☰</span>
                </button>
                <div class="top-bar-title">{{ title }}</div>
                <div class="top-bar-links">
                    <a href="{{ git_repository_url }}" class="icon-button">GitHub</a>
                </div>
            </div>

            <div id="content" class="content">
                {{{ content }}}
            </div>

            <!-- Navigation -->
            <nav class="nav-wrapper" aria-label="Page navigation">
                {{#previous}}
                <a href="{{ path_to_root }}{{link}}" class="nav-chapters previous">←</a>
                {{/previous}}
                {{#next}}
                <a href="{{ path_to_root }}{{link}}" class="nav-chapters next">→</a>
                {{/next}}
            </nav>
        </main>
    </div>

    <script>
        // Simple Sidebar Toggle
        const toggle = document.getElementById('sidebar-toggle');
        const body = document.body;

        toggle.addEventListener('click', () => {
            body.classList.toggle('sidebar-hidden');
        });

        // Handle Mobile Auto-hide
        if (window.innerWidth < 1080) {
            body.classList.add('sidebar-hidden');
        }
    </script>
</body>

</html>