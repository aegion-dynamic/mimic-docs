<!DOCTYPE html>
<html lang="{{ language }}" class="sidebar-visible no-js">

<head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="{{ path_to_root }}theme/css/general.css">
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    {{{ head }}}
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10.9.0/dist/mermaid.min.js"></script>
    <script>
      document.addEventListener("DOMContentLoaded", function() {
          var blocks = document.querySelectorAll("pre code.language-mermaid");
          blocks.forEach(function(block) {
              var pre = block.parentNode;
              var div = document.createElement("div");
              div.className = "mermaid";
              div.textContent = block.textContent;
              pre.parentNode.replaceChild(div, pre);
          });
          mermaid.initialize({
              startOnLoad: true,
              theme: "base",
              themeVariables: {
                  primaryColor: '#1a1a2e',
                  primaryTextColor: '#ffffff',
                  primaryBorderColor: '#3a3a5c',
                  lineColor: '#5a5a7a',
                  fontFamily: 'Space Mono, monospace',
                  fontSize: '13px'
              },
              flowchart: { curve: 'basis' }
          });
      });
    </script>
</head>

<body>
    <div id="container">
        <!-- Sidebar -->
        <nav id="sidebar" class="sidebar" aria-label="Table of contents">
            <div class="sidebar-header">
                <a href="{{ path_to_root }}../index.html" class="sidebar-logo">Mimic<span>_</span></a>
            </div>
            <div class="sidebar-scrollbox">
                {{{ toc }}}
            </div>
        </nav>

        <!-- Main Content -->
        <main id="main">
            <div class="top-bar">
                <button id="sidebar-toggle" class="icon-button" aria-label="Toggle Table of Contents">
                    <span>☰</span>
                </button>
                <div class="top-bar-title">{{ title }}</div>
                <div class="top-bar-links">
                    <a href="{{ git_repository_url }}" class="icon-button">GitHub</a>
                </div>
            </div>

            <div id="content" class="content">
                {{{ content }}}
            </div>

            <!-- Navigation -->
            <nav class="nav-wrapper" aria-label="Page navigation">
                {{#previous}}
                <a href="{{ path_to_root }}{{link}}" class="nav-chapters previous">←</a>
                {{/previous}}
                {{#next}}
                <a href="{{ path_to_root }}{{link}}" class="nav-chapters next">→</a>
                {{/next}}
            </nav>
        </main>
    </div>

    <script>
        // Sidebar Toggle
        const toggle = document.getElementById('sidebar-toggle');
        const body = document.body;

        toggle.addEventListener('click', () => {
            body.classList.toggle('sidebar-hidden');
        });

        // Mobile: auto-hide sidebar
        if (window.innerWidth < 1080) {
            body.classList.add('sidebar-hidden');
        }
    </script>
</body>

</html>