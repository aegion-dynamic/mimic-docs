 183:Core/Src/mimic.c ****     
 184:Core/Src/mimic.c ****     /* Get command */
 185:Core/Src/mimic.c ****     token = strtok(buffer, " \t");
 186:Core/Src/mimic.c ****     if (token == NULL) return 0;
 187:Core/Src/mimic.c ****     
