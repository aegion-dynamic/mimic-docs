1013:Core/Src/mimic.c ****     Mimic_SendResponse("\r\n"); // End live line
1014:Core/Src/mimic.c ****     
1015:Core/Src/mimic.c ****     uint32_t elapsed = HAL_GetTick() - start_time;
1016:Core/Src/mimic.c ****     
1017:Core/Src/mimic.c ****     /* Output Final Summary */
1018:Core/Src/mimic.c ****     if (rx_count > 0)
1019:Core/Src/mimic.c ****     {
1020:Core/Src/mimic.c ****         buffer[rx_count] = '\0';
1021:Core/Src/mimic.c ****         
