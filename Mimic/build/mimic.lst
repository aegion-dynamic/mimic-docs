 124:Core/Src/mimic.c **** /**
 125:Core/Src/mimic.c ****   * @brief  Process incoming commands (call in main loop)
 126:Core/Src/mimic.c ****   */
 127:Core/Src/mimic.c **** void Mimic_Process(void)
 128:Core/Src/mimic.c **** {
 129:Core/Src/mimic.c ****     /* Process all available bytes from interrupt buffer */
 130:Core/Src/mimic.c ****     while (Mimic_RxAvailable())
 131:Core/Src/mimic.c ****     {
 132:Core/Src/mimic.c ****         uint8_t rx = Mimic_RxGet();
 133:Core/Src/mimic.c ****         
 134:Core/Src/mimic.c ****         /* Echo back */
 135:Core/Src/mimic.c ****         HAL_UART_Transmit(&MIMIC_HOST_UART, &rx, 1, 10);
 136:Core/Src/mimic.c ****         
 137:Core/Src/mimic.c ****         /* Handle special characters */
 138:Core/Src/mimic.c ****         if (rx == '\r' || rx == '\n')
 139:Core/Src/mimic.c ****         {
 140:Core/Src/mimic.c ****             if (mimic_state.cmd_index > 0)
 141:Core/Src/mimic.c ****             {
 142:Core/Src/mimic.c ****                 Mimic_SendResponse("\r\n");
 143:Core/Src/mimic.c ****                 mimic_state.cmd_buffer[mimic_state.cmd_index] = '\0';
 144:Core/Src/mimic.c ****                 Mimic_ProcessCommand(mimic_state.cmd_buffer);
 145:Core/Src/mimic.c ****                 mimic_state.cmd_index = 0;
 146:Core/Src/mimic.c ****                 Mimic_SendResponse("> ");
 147:Core/Src/mimic.c ****             }
 148:Core/Src/mimic.c ****         }
 149:Core/Src/mimic.c ****         else if (rx == '\b' || rx == 127)  /* Backspace */
 150:Core/Src/mimic.c ****         {
 151:Core/Src/mimic.c ****             if (mimic_state.cmd_index > 0)
 152:Core/Src/mimic.c ****             {
 153:Core/Src/mimic.c ****                 mimic_state.cmd_index--;
 154:Core/Src/mimic.c ****                 Mimic_SendResponse(" \b");  /* Erase character */
 155:Core/Src/mimic.c ****             }
 156:Core/Src/mimic.c ****         }
 157:Core/Src/mimic.c ****         else if (rx >= 32 && rx < 127)  /* Printable */
 158:Core/Src/mimic.c ****         {
 159:Core/Src/mimic.c ****             if (mimic_state.cmd_index < MIMIC_MAX_CMD_LEN - 1)
 160:Core/Src/mimic.c ****             {
 161:Core/Src/mimic.c ****                 mimic_state.cmd_buffer[mimic_state.cmd_index++] = rx;
 162:Core/Src/mimic.c ****             }
 163:Core/Src/mimic.c ****         }
 164:Core/Src/mimic.c ****     }
 165:Core/Src/mimic.c **** }
 166:Core/Src/mimic.c **** 
 167:Core/Src/mimic.c **** /**
 168:Core/Src/mimic.c ****   * @brief  Send response string
 169:Core/Src/mimic.c ****   */
 170:Core/Src/mimic.c **** void Mimic_SendResponse(const char *response)
 171:Core/Src/mimic.c **** {
 172:Core/Src/mimic.c ****     HAL_UART_Transmit(&MIMIC_HOST_UART, (uint8_t*)response, strlen(response), 100);
 173:Core/Src/mimic.c **** }
