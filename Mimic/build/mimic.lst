  86:Core/Src/mimic.c **** /**
  87:Core/Src/mimic.c ****   * @brief  Initialize Mimic command interface
  88:Core/Src/mimic.c ****   */
  89:Core/Src/mimic.c **** void Mimic_Init(void)
  90:Core/Src/mimic.c **** {
  91:Core/Src/mimic.c ****     memset(&mimic_state, 0, sizeof(Mimic_CmdState_t));
  92:Core/Src/mimic.c ****     
  93:Core/Src/mimic.c ****     /* Start interrupt-based reception */
  94:Core/Src/mimic.c ****     HAL_UART_Receive_IT(&MIMIC_HOST_UART, (uint8_t*)&rx_byte, 1);
  95:Core/Src/mimic.c ****     
  96:Core/Src/mimic.c ****     /* Send welcome message */
  97:Core/Src/mimic.c ****     Mimic_SendResponse("\r\n");
  98:Core/Src/mimic.c ****     Mimic_SendResponse("========================================\r\n");
  99:Core/Src/mimic.c ****     Mimic_SendResponse("  MIMIC - Hardware Control Interface\r\n");
 100:Core/Src/mimic.c ****     Mimic_SendResponseF("  Version: %s\r\n", MIMIC_VERSION);
 101:Core/Src/mimic.c ****     Mimic_SendResponse("  Type 'HELP' for commands\r\n");
 102:Core/Src/mimic.c ****     Mimic_SendResponse("========================================\r\n");
 103:Core/Src/mimic.c ****     Mimic_SendResponse("READY\r\n> ");
 104:Core/Src/mimic.c **** }
 105:Core/Src/mimic.c **** 
 106:Core/Src/mimic.c **** /**
 107:Core/Src/mimic.c ****   * @brief  Process incoming commands (call in main loop)
 108:Core/Src/mimic.c ****   */
 109:Core/Src/mimic.c **** void Mimic_Process(void)
 110:Core/Src/mimic.c **** {
 111:Core/Src/mimic.c ****     /* Process all available bytes from interrupt buffer */
 112:Core/Src/mimic.c ****     while (Mimic_RxAvailable())
 113:Core/Src/mimic.c ****     {
 114:Core/Src/mimic.c ****         uint8_t rx = Mimic_RxGet();
 115:Core/Src/mimic.c ****         
 116:Core/Src/mimic.c ****         /* Echo back */
 117:Core/Src/mimic.c ****         HAL_UART_Transmit(&MIMIC_HOST_UART, &rx, 1, 10);
 118:Core/Src/mimic.c ****         
 119:Core/Src/mimic.c ****         /* Handle special characters */
 120:Core/Src/mimic.c ****         if (rx == '\r' || rx == '\n')
 121:Core/Src/mimic.c ****         {
 122:Core/Src/mimic.c ****             if (mimic_state.cmd_index > 0)
ARM GAS  /tmp/ccVx3Gtk.s 			page 46


 123:Core/Src/mimic.c ****             {
 124:Core/Src/mimic.c ****                 Mimic_SendResponse("\r\n");
 125:Core/Src/mimic.c ****                 mimic_state.cmd_buffer[mimic_state.cmd_index] = '\0';
 126:Core/Src/mimic.c ****                 Mimic_ProcessCommand(mimic_state.cmd_buffer);
 127:Core/Src/mimic.c ****                 mimic_state.cmd_index = 0;
 128:Core/Src/mimic.c ****                 Mimic_SendResponse("> ");
 129:Core/Src/mimic.c ****             }
 130:Core/Src/mimic.c ****         }
 131:Core/Src/mimic.c ****         else if (rx == '\b' || rx == 127)  /* Backspace */
 132:Core/Src/mimic.c ****         {
 133:Core/Src/mimic.c ****             if (mimic_state.cmd_index > 0)
 134:Core/Src/mimic.c ****             {
 135:Core/Src/mimic.c ****                 mimic_state.cmd_index--;
 136:Core/Src/mimic.c ****                 Mimic_SendResponse(" \b");  /* Erase character */
 137:Core/Src/mimic.c ****             }
 138:Core/Src/mimic.c ****         }
 139:Core/Src/mimic.c ****         else if (rx >= 32 && rx < 127)  /* Printable */
 140:Core/Src/mimic.c ****         {
 141:Core/Src/mimic.c ****             if (mimic_state.cmd_index < MIMIC_MAX_CMD_LEN - 1)
 142:Core/Src/mimic.c ****             {
 143:Core/Src/mimic.c ****                 mimic_state.cmd_buffer[mimic_state.cmd_index++] = rx;
 144:Core/Src/mimic.c ****             }
 145:Core/Src/mimic.c ****         }
 146:Core/Src/mimic.c ****     }
 147:Core/Src/mimic.c **** }
 148:Core/Src/mimic.c **** 
 149:Core/Src/mimic.c **** /**
 150:Core/Src/mimic.c ****   * @brief  Send response string
 151:Core/Src/mimic.c ****   */
 152:Core/Src/mimic.c **** void Mimic_SendResponse(const char *response)
 153:Core/Src/mimic.c **** {
 154:Core/Src/mimic.c ****     HAL_UART_Transmit(&MIMIC_HOST_UART, (uint8_t*)response, strlen(response), 100);
 155:Core/Src/mimic.c **** }
