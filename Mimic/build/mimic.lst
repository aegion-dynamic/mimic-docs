 302:Core/Src/mimic.c **** /**
 303:Core/Src/mimic.c ****   * @brief  Get GPIO port from character
 304:Core/Src/mimic.c ****   */
 305:Core/Src/mimic.c **** GPIO_TypeDef* Mimic_GetPort(char port_char)
 306:Core/Src/mimic.c **** {
 307:Core/Src/mimic.c ****     char upper = (port_char >= 'a' && port_char <= 'z') ? port_char - 32 : port_char;
 308:Core/Src/mimic.c ****     
 309:Core/Src/mimic.c ****     for (int i = 0; port_map[i].port != NULL; i++)
 310:Core/Src/mimic.c ****     {
 311:Core/Src/mimic.c ****         if (port_map[i].name == upper)
 312:Core/Src/mimic.c ****         {
 313:Core/Src/mimic.c ****             return port_map[i].port;
 314:Core/Src/mimic.c ****         }
 315:Core/Src/mimic.c ****     }
 316:Core/Src/mimic.c ****     return NULL;
 317:Core/Src/mimic.c **** }
 318:Core/Src/mimic.c **** 
 319:Core/Src/mimic.c **** /**
 320:Core/Src/mimic.c ****   * @brief  Get GPIO pin mask from number
 321:Core/Src/mimic.c ****   */
 322:Core/Src/mimic.c **** uint16_t Mimic_GetPin(uint8_t pin_num)
 323:Core/Src/mimic.c **** {
 324:Core/Src/mimic.c ****     if (pin_num > 15) return 0;
 325:Core/Src/mimic.c ****     return (1 << pin_num);
 326:Core/Src/mimic.c **** }
 327:Core/Src/mimic.c **** 
 328:Core/Src/mimic.c **** /**
 329:Core/Src/mimic.c ****   * @brief  Parse pin string like "A5" or "D12"
 330:Core/Src/mimic.c ****   */
 331:Core/Src/mimic.c **** uint8_t Mimic_ParsePin(const char *pin_str, GPIO_TypeDef **port, uint16_t *pin)
 332:Core/Src/mimic.c **** {
 333:Core/Src/mimic.c ****     if (strlen(pin_str) < 2) return 0;
 334:Core/Src/mimic.c ****     
 335:Core/Src/mimic.c ****     *port = Mimic_GetPort(pin_str[0]);
 336:Core/Src/mimic.c ****     if (*port == NULL) return 0;
 337:Core/Src/mimic.c ****     
 338:Core/Src/mimic.c ****     uint8_t pin_num = atoi(&pin_str[1]);
 339:Core/Src/mimic.c ****     *pin = Mimic_GetPin(pin_num);
 340:Core/Src/mimic.c ****     if (*pin == 0 && pin_str[1] != '0') return 0;
 341:Core/Src/mimic.c ****     
 342:Core/Src/mimic.c ****     return 1;
 343:Core/Src/mimic.c **** }
