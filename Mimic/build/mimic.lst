 198:Core/Src/mimic.c ****     }
 199:Core/Src/mimic.c ****     cmd->argc = idx;
 200:Core/Src/mimic.c ****     
 201:Core/Src/mimic.c ****     return 1;
 202:Core/Src/mimic.c **** }
