 172:Core/Src/mimic.c **** /**
 173:Core/Src/mimic.c ****   * @brief  Parse command line into command structure
 174:Core/Src/mimic.c ****   */
 175:Core/Src/mimic.c **** uint8_t Mimic_ParseCommand(const char *cmd_line, Mimic_Command_t *cmd)
 176:Core/Src/mimic.c **** {
 177:Core/Src/mimic.c ****     char buffer[MIMIC_MAX_CMD_LEN];
 178:Core/Src/mimic.c ****     char *token;
 179:Core/Src/mimic.c ****     uint8_t idx = 0;
