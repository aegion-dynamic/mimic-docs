 190:Core/Src/mimic.c **** /**
 191:Core/Src/mimic.c ****   * @brief  Parse command line into command structure
 192:Core/Src/mimic.c ****   */
 193:Core/Src/mimic.c **** uint8_t Mimic_ParseCommand(const char *cmd_line, Mimic_Command_t *cmd)
 194:Core/Src/mimic.c **** {
 195:Core/Src/mimic.c ****     char buffer[MIMIC_MAX_CMD_LEN];
 196:Core/Src/mimic.c ****     char *token;
 197:Core/Src/mimic.c ****     uint8_t idx = 0;
 198:Core/Src/mimic.c ****     
 199:Core/Src/mimic.c ****     memset(cmd, 0, sizeof(Mimic_Command_t));
 200:Core/Src/mimic.c ****     strncpy(buffer, cmd_line, MIMIC_MAX_CMD_LEN - 1);
 201:Core/Src/mimic.c ****     
 202:Core/Src/mimic.c ****     /* Get command */
 203:Core/Src/mimic.c ****     token = strtok(buffer, " \t");
 204:Core/Src/mimic.c ****     if (token == NULL) return 0;
 205:Core/Src/mimic.c ****     
 206:Core/Src/mimic.c ****     /* Convert to uppercase */
 207:Core/Src/mimic.c ****     for (int i = 0; token[i]; i++) {
 208:Core/Src/mimic.c ****         cmd->command[i] = (token[i] >= 'a' && token[i] <= 'z') ? token[i] - 32 : token[i];
 209:Core/Src/mimic.c ****     }
 210:Core/Src/mimic.c ****     
 211:Core/Src/mimic.c ****     /* Get arguments */
 212:Core/Src/mimic.c ****     while ((token = strtok(NULL, " \t")) != NULL && idx < MIMIC_MAX_ARGS)
 213:Core/Src/mimic.c ****     {
 214:Core/Src/mimic.c ****         strncpy(cmd->args[idx], token, MIMIC_MAX_ARG_LEN - 1);
 215:Core/Src/mimic.c ****         idx++;
 216:Core/Src/mimic.c ****     }
 217:Core/Src/mimic.c ****     cmd->argc = idx;
 218:Core/Src/mimic.c ****     
 219:Core/Src/mimic.c ****     return 1;
 220:Core/Src/mimic.c **** }
