 104:Core/Src/mimic.c **** /**
 105:Core/Src/mimic.c ****   * @brief  Initialize Mimic command interface
 106:Core/Src/mimic.c ****   */
 107:Core/Src/mimic.c **** void Mimic_Init(void)
 108:Core/Src/mimic.c **** {
 109:Core/Src/mimic.c ****     memset(&mimic_state, 0, sizeof(Mimic_CmdState_t));
 110:Core/Src/mimic.c ****     
 111:Core/Src/mimic.c ****     /* Start interrupt-based reception */
 112:Core/Src/mimic.c ****     HAL_UART_Receive_IT(&MIMIC_HOST_UART, (uint8_t*)&rx_byte, 1);
 113:Core/Src/mimic.c ****     
 114:Core/Src/mimic.c ****     /* Send welcome message */
 115:Core/Src/mimic.c ****     Mimic_SendResponse("\r\n");
 116:Core/Src/mimic.c ****     Mimic_SendResponse("========================================\r\n");
 117:Core/Src/mimic.c ****     Mimic_SendResponse("  MIMIC - Hardware Control Interface\r\n");
 118:Core/Src/mimic.c ****     Mimic_SendResponseF("  Version: %s\r\n", MIMIC_VERSION);
 119:Core/Src/mimic.c ****     Mimic_SendResponse("  Type 'HELP' for commands\r\n");
 120:Core/Src/mimic.c ****     Mimic_SendResponse("========================================\r\n");
 121:Core/Src/mimic.c ****     Mimic_SendResponse("READY\r\n> ");
 122:Core/Src/mimic.c **** }
