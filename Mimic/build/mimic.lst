 370:Core/Src/mimic.c **** /**
 371:Core/Src/mimic.c ****   * @brief  Get GPIO port from character
 372:Core/Src/mimic.c ****   */
 373:Core/Src/mimic.c **** GPIO_TypeDef* Mimic_GetPort(char port_char)
 374:Core/Src/mimic.c **** {
 375:Core/Src/mimic.c ****     char upper = (port_char >= 'a' && port_char <= 'z') ? port_char - 32 : port_char;
 376:Core/Src/mimic.c ****     
 377:Core/Src/mimic.c ****     for (int i = 0; port_map[i].port != NULL; i++)
 378:Core/Src/mimic.c ****     {
 379:Core/Src/mimic.c ****         if (port_map[i].name == upper)
 380:Core/Src/mimic.c ****         {
 381:Core/Src/mimic.c ****             return port_map[i].port;
 382:Core/Src/mimic.c ****         }
 383:Core/Src/mimic.c ****     }
 384:Core/Src/mimic.c ****     return NULL;
 385:Core/Src/mimic.c **** }
 386:Core/Src/mimic.c **** 
 387:Core/Src/mimic.c **** /**
 388:Core/Src/mimic.c ****   * @brief  Get GPIO pin mask from number
 389:Core/Src/mimic.c ****   */
 390:Core/Src/mimic.c **** uint16_t Mimic_GetPin(uint8_t pin_num)
 391:Core/Src/mimic.c **** {
 392:Core/Src/mimic.c ****     if (pin_num > 15) return 0;
 393:Core/Src/mimic.c ****     return (1 << pin_num);
 394:Core/Src/mimic.c **** }
 395:Core/Src/mimic.c **** 
 396:Core/Src/mimic.c **** /**
 397:Core/Src/mimic.c ****   * @brief  Parse pin string like "A5" or "D12"
 398:Core/Src/mimic.c ****   */
 399:Core/Src/mimic.c **** uint8_t Mimic_ParsePin(const char *pin_str, GPIO_TypeDef **port, uint16_t *pin)
 400:Core/Src/mimic.c **** {
 401:Core/Src/mimic.c ****     if (strlen(pin_str) < 2) return 0;
 402:Core/Src/mimic.c ****     
 403:Core/Src/mimic.c ****     *port = Mimic_GetPort(pin_str[0]);
 404:Core/Src/mimic.c ****     if (*port == NULL) return 0;
 405:Core/Src/mimic.c ****     
 406:Core/Src/mimic.c ****     uint8_t pin_num = atoi(&pin_str[1]);
 407:Core/Src/mimic.c ****     *pin = Mimic_GetPin(pin_num);
ARM GAS  /tmp/cco4sx1B.s 			page 51


 408:Core/Src/mimic.c ****     if (*pin == 0 && pin_str[1] != '0') return 0;
 409:Core/Src/mimic.c ****     
 410:Core/Src/mimic.c ****     return 1;
 411:Core/Src/mimic.c **** }
