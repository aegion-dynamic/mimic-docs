 974:Core/Src/mimic.c ****     /* Live Polling Strategy:
 975:Core/Src/mimic.c ****        1. Loop until 'length' bytes received OR 'timeout' expires.
 976:Core/Src/mimic.c ****        2. Read byte-by-byte with a short timeout to check for data.
 977:Core/Src/mimic.c ****        3. Echo received characters immediately ("Live Polling").
 978:Core/Src/mimic.c ****        4. Return full/partial buffer at the end.
 979:Core/Src/mimic.c ****     */
 980:Core/Src/mimic.c ****     
 981:Core/Src/mimic.c ****     uint8_t buffer[65] = {0};
 982:Core/Src/mimic.c ****     uint16_t rx_count = 0;
 983:Core/Src/mimic.c ****     uint32_t start_time = HAL_GetTick();
 984:Core/Src/mimic.c ****     
 985:Core/Src/mimic.c ****     Mimic_SendResponse("LIVE: "); // Prefix for live stream
 986:Core/Src/mimic.c ****     
 987:Core/Src/mimic.c ****     while (rx_count < length)
 988:Core/Src/mimic.c ****     {
 989:Core/Src/mimic.c ****         /* Check for total timeout */
 990:Core/Src/mimic.c ****         if ((HAL_GetTick() - start_time) > timeout)
 991:Core/Src/mimic.c ****         {
 992:Core/Src/mimic.c ****             break;
 993:Core/Src/mimic.c ****         }
 994:Core/Src/mimic.c ****         
 995:Core/Src/mimic.c ****         /* Try to read 1 byte with short timeout (10ms) 
 996:Core/Src/mimic.c ****            10ms allows checking 'timeout' frequently enough 
 997:Core/Src/mimic.c ****         */
 998:Core/Src/mimic.c ****         uint8_t byte = 0;
 999:Core/Src/mimic.c ****         if (HAL_UART_Receive(huart, &byte, 1, 10) == HAL_OK)
1000:Core/Src/mimic.c ****         {
1001:Core/Src/mimic.c ****             buffer[rx_count++] = byte;
1002:Core/Src/mimic.c ****             
1003:Core/Src/mimic.c ****             /* Live Echo: Print char if printable, else dot */
1004:Core/Src/mimic.c ****             if (byte >= 32 && byte <= 126)
1005:Core/Src/mimic.c ****                 Mimic_SendResponseF("%c", byte);
1006:Core/Src/mimic.c ****             else if (byte == '\r' || byte == '\n')
1007:Core/Src/mimic.c ****                  Mimic_SendResponseF("%c", byte); // Pass newlines
1008:Core/Src/mimic.c ****             else
1009:Core/Src/mimic.c ****                 Mimic_SendResponse(".");
