 415:Core/Src/mimic.c **** /**
 416:Core/Src/mimic.c ****   * @brief  PIN_STATUS <PIN> - Show pin configuration
 417:Core/Src/mimic.c ****   */
 418:Core/Src/mimic.c **** void Mimic_CMD_PIN_STATUS(Mimic_Command_t *cmd)
 419:Core/Src/mimic.c **** {
 420:Core/Src/mimic.c ****     GPIO_TypeDef *port;
 421:Core/Src/mimic.c ****     uint16_t pin;
 422:Core/Src/mimic.c ****     
 423:Core/Src/mimic.c ****     if (cmd->argc < 1)
 424:Core/Src/mimic.c ****     {
 425:Core/Src/mimic.c ****         Mimic_SendResponse("Usage: PIN_STATUS <PIN> (e.g., PIN_STATUS A5)\r\n");
 426:Core/Src/mimic.c ****         return;
 427:Core/Src/mimic.c ****     }
 428:Core/Src/mimic.c ****     
 429:Core/Src/mimic.c ****     if (!Mimic_ParsePin(cmd->args[0], &port, &pin))
 430:Core/Src/mimic.c ****     {
 431:Core/Src/mimic.c ****         Mimic_SendResponseF("ERROR: Invalid pin '%s'\r\n", cmd->args[0]);
 432:Core/Src/mimic.c ****         return;
 433:Core/Src/mimic.c ****     }
 434:Core/Src/mimic.c ****     
 435:Core/Src/mimic.c ****     uint8_t pin_num = 0;
 436:Core/Src/mimic.c ****     for (int i = 0; i < 16; i++) {
 437:Core/Src/mimic.c ****         if (pin & (1 << i)) { pin_num = i; break; }
 438:Core/Src/mimic.c ****     }
 439:Core/Src/mimic.c ****     
 440:Core/Src/mimic.c ****     /* Read MODER */
 441:Core/Src/mimic.c ****     uint32_t moder = (port->MODER >> (pin_num * 2)) & 0x03;
 442:Core/Src/mimic.c ****     const char *mode_str[] = {"INPUT", "OUTPUT", "ALT_FUNC", "ANALOG"};
 443:Core/Src/mimic.c ****     
 444:Core/Src/mimic.c ****     /* Read OTYPER */
 445:Core/Src/mimic.c ****     uint32_t otyper = (port->OTYPER >> pin_num) & 0x01;
 446:Core/Src/mimic.c ****     const char *otype_str[] = {"PUSH_PULL", "OPEN_DRAIN"};
 447:Core/Src/mimic.c ****     
 448:Core/Src/mimic.c ****     /* Read OSPEEDR */
 449:Core/Src/mimic.c ****     uint32_t ospeedr = (port->OSPEEDR >> (pin_num * 2)) & 0x03;
 450:Core/Src/mimic.c ****     const char *speed_str[] = {"LOW", "MEDIUM", "HIGH", "VERY_HIGH"};
 451:Core/Src/mimic.c ****     
 452:Core/Src/mimic.c ****     /* Read PUPDR */
 453:Core/Src/mimic.c ****     uint32_t pupdr = (port->PUPDR >> (pin_num * 2)) & 0x03;
 454:Core/Src/mimic.c ****     const char *pupd_str[] = {"NONE", "PULL_UP", "PULL_DOWN", "RESERVED"};
 455:Core/Src/mimic.c ****     
 456:Core/Src/mimic.c ****     /* Read current state */
 457:Core/Src/mimic.c ****     uint8_t state = HAL_GPIO_ReadPin(port, pin);
 458:Core/Src/mimic.c ****     
 459:Core/Src/mimic.c ****     Mimic_SendResponseF("PIN %s:\r\n", cmd->args[0]);
 460:Core/Src/mimic.c ****     Mimic_SendResponseF("  Mode:   %s\r\n", mode_str[moder]);
 461:Core/Src/mimic.c ****     Mimic_SendResponseF("  Type:   %s\r\n", otype_str[otyper]);
 462:Core/Src/mimic.c ****     Mimic_SendResponseF("  Speed:  %s\r\n", speed_str[ospeedr]);
 463:Core/Src/mimic.c ****     Mimic_SendResponseF("  Pull:   %s\r\n", pupd_str[pupdr]);
 464:Core/Src/mimic.c ****     Mimic_SendResponseF("  State:  %s\r\n", state ? "HIGH" : "LOW");
ARM GAS  /tmp/cco4sx1B.s 			page 52


 465:Core/Src/mimic.c **** }
