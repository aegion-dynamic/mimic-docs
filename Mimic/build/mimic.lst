 348:Core/Src/mimic.c ****   * @brief  PIN_STATUS <PIN> - Show pin configuration
 349:Core/Src/mimic.c ****   */
 350:Core/Src/mimic.c **** void Mimic_CMD_PIN_STATUS(Mimic_Command_t *cmd)
ARM GAS  /tmp/ccVx3Gtk.s 			page 50


 351:Core/Src/mimic.c **** {
 352:Core/Src/mimic.c ****     GPIO_TypeDef *port;
 353:Core/Src/mimic.c ****     uint16_t pin;
 354:Core/Src/mimic.c ****     
 355:Core/Src/mimic.c ****     if (cmd->argc < 1)
 356:Core/Src/mimic.c ****     {
 357:Core/Src/mimic.c ****         Mimic_SendResponse("Usage: PIN_STATUS <PIN> (e.g., PIN_STATUS A5)\r\n");
 358:Core/Src/mimic.c ****         return;
 359:Core/Src/mimic.c ****     }
 360:Core/Src/mimic.c ****     
 361:Core/Src/mimic.c ****     if (!Mimic_ParsePin(cmd->args[0], &port, &pin))
 362:Core/Src/mimic.c ****     {
 363:Core/Src/mimic.c ****         Mimic_SendResponseF("ERROR: Invalid pin '%s'\r\n", cmd->args[0]);
 364:Core/Src/mimic.c ****         return;
 365:Core/Src/mimic.c ****     }
 366:Core/Src/mimic.c ****     
 367:Core/Src/mimic.c ****     uint8_t pin_num = 0;
 368:Core/Src/mimic.c ****     for (int i = 0; i < 16; i++) {
 369:Core/Src/mimic.c ****         if (pin & (1 << i)) { pin_num = i; break; }
 370:Core/Src/mimic.c ****     }
 371:Core/Src/mimic.c ****     
 372:Core/Src/mimic.c ****     /* Read MODER */
 373:Core/Src/mimic.c ****     uint32_t moder = (port->MODER >> (pin_num * 2)) & 0x03;
 374:Core/Src/mimic.c ****     const char *mode_str[] = {"INPUT", "OUTPUT", "ALT_FUNC", "ANALOG"};
 375:Core/Src/mimic.c ****     
 376:Core/Src/mimic.c ****     /* Read OTYPER */
 377:Core/Src/mimic.c ****     uint32_t otyper = (port->OTYPER >> pin_num) & 0x01;
 378:Core/Src/mimic.c ****     const char *otype_str[] = {"PUSH_PULL", "OPEN_DRAIN"};
 379:Core/Src/mimic.c ****     
 380:Core/Src/mimic.c ****     /* Read OSPEEDR */
 381:Core/Src/mimic.c ****     uint32_t ospeedr = (port->OSPEEDR >> (pin_num * 2)) & 0x03;
 382:Core/Src/mimic.c ****     const char *speed_str[] = {"LOW", "MEDIUM", "HIGH", "VERY_HIGH"};
 383:Core/Src/mimic.c ****     
 384:Core/Src/mimic.c ****     /* Read PUPDR */
 385:Core/Src/mimic.c ****     uint32_t pupdr = (port->PUPDR >> (pin_num * 2)) & 0x03;
 386:Core/Src/mimic.c ****     const char *pupd_str[] = {"NONE", "PULL_UP", "PULL_DOWN", "RESERVED"};
 387:Core/Src/mimic.c ****     
 388:Core/Src/mimic.c ****     /* Read current state */
 389:Core/Src/mimic.c ****     uint8_t state = HAL_GPIO_ReadPin(port, pin);
 390:Core/Src/mimic.c ****     
 391:Core/Src/mimic.c ****     Mimic_SendResponseF("PIN %s:\r\n", cmd->args[0]);
 392:Core/Src/mimic.c ****     Mimic_SendResponseF("  Mode:   %s\r\n", mode_str[moder]);
 393:Core/Src/mimic.c ****     Mimic_SendResponseF("  Type:   %s\r\n", otype_str[otyper]);
 394:Core/Src/mimic.c ****     Mimic_SendResponseF("  Speed:  %s\r\n", speed_str[ospeedr]);
 395:Core/Src/mimic.c ****     Mimic_SendResponseF("  Pull:   %s\r\n", pupd_str[pupdr]);
 396:Core/Src/mimic.c ****     Mimic_SendResponseF("  State:  %s\r\n", state ? "HIGH" : "LOW");
 397:Core/Src/mimic.c **** }
