 157:Core/Src/mimic.c **** /**
 158:Core/Src/mimic.c ****   * @brief  Send formatted response
 159:Core/Src/mimic.c ****   */
 160:Core/Src/mimic.c **** void Mimic_SendResponseF(const char *format, ...)
 161:Core/Src/mimic.c **** {
 162:Core/Src/mimic.c ****     char buffer[MIMIC_MAX_CMD_LEN];
 163:Core/Src/mimic.c ****     va_list args;
 164:Core/Src/mimic.c ****     va_start(args, format);
 165:Core/Src/mimic.c ****     vsnprintf(buffer, sizeof(buffer), format, args);
 166:Core/Src/mimic.c ****     va_end(args);
 167:Core/Src/mimic.c ****     Mimic_SendResponse(buffer);
 168:Core/Src/mimic.c **** }
