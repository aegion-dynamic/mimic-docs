1069:Core/Src/mimic.c ****         
1070:Core/Src/mimic.c ****         /* Try to read 1 byte with short timeout (10ms) 
1071:Core/Src/mimic.c ****            10ms allows checking 'timeout' frequently enough 
1072:Core/Src/mimic.c ****         */
