1137:Core/Src/mimic.c ****                 Mimic_SendResponseF("%c", byte);
1138:Core/Src/mimic.c ****             else if (byte == '\r' || byte == '\n')
1139:Core/Src/mimic.c ****                  Mimic_SendResponseF("%c", byte); // Pass newlines
1140:Core/Src/mimic.c ****             else
1141:Core/Src/mimic.c ****                 Mimic_SendResponse(".");
1142:Core/Src/mimic.c ****         }
1143:Core/Src/mimic.c ****     }
1144:Core/Src/mimic.c ****     
1145:Core/Src/mimic.c ****     Mimic_SendResponse("\r\n"); // End live line
1146:Core/Src/mimic.c ****     
1147:Core/Src/mimic.c ****     uint32_t elapsed = HAL_GetTick() - start_time;
1148:Core/Src/mimic.c ****     
1149:Core/Src/mimic.c ****     /* Output Final Summary */
1150:Core/Src/mimic.c ****     if (rx_count > 0)
1151:Core/Src/mimic.c ****     {
1152:Core/Src/mimic.c ****         buffer[rx_count] = '\0';
1153:Core/Src/mimic.c ****         
1154:Core/Src/mimic.c ****         if (rx_count < length)
1155:Core/Src/mimic.c ****              Mimic_SendResponseF("PARTIAL (Time: %lu ms, %d/%d bytes): ", elapsed, rx_count, length
1156:Core/Src/mimic.c ****         else
