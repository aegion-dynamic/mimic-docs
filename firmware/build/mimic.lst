 430:Core/Src/mimic.c **** /**
ARM GAS  /tmp/cc3MLRqL.s 			page 51


 431:Core/Src/mimic.c ****   * @brief  Get GPIO port from character
 432:Core/Src/mimic.c ****   */
 433:Core/Src/mimic.c **** GPIO_TypeDef* Mimic_GetPort(char port_char)
 434:Core/Src/mimic.c **** {
 435:Core/Src/mimic.c ****     char upper = (port_char >= 'a' && port_char <= 'z') ? port_char - 32 : port_char;
 436:Core/Src/mimic.c ****     
 437:Core/Src/mimic.c ****     for (int i = 0; port_map[i].port != NULL; i++)
 438:Core/Src/mimic.c ****     {
 439:Core/Src/mimic.c ****         if (port_map[i].name == upper)
 440:Core/Src/mimic.c ****         {
 441:Core/Src/mimic.c ****             return port_map[i].port;
 442:Core/Src/mimic.c ****         }
 443:Core/Src/mimic.c ****     }
 444:Core/Src/mimic.c ****     return NULL;
 445:Core/Src/mimic.c **** }
 446:Core/Src/mimic.c **** 
 447:Core/Src/mimic.c **** /**
 448:Core/Src/mimic.c ****   * @brief  Get GPIO pin mask from number
 449:Core/Src/mimic.c ****   */
 450:Core/Src/mimic.c **** uint16_t Mimic_GetPin(uint8_t pin_num)
 451:Core/Src/mimic.c **** {
 452:Core/Src/mimic.c ****     if (pin_num > 15) return 0;
 453:Core/Src/mimic.c ****     return (1 << pin_num);
 454:Core/Src/mimic.c **** }
 455:Core/Src/mimic.c **** 
 456:Core/Src/mimic.c **** /**
 457:Core/Src/mimic.c ****   * @brief  Parse pin string like "A5" or "D12"
 458:Core/Src/mimic.c ****   */
 459:Core/Src/mimic.c **** uint8_t Mimic_ParsePin(const char *pin_str, GPIO_TypeDef **port, uint16_t *pin)
 460:Core/Src/mimic.c **** {
 461:Core/Src/mimic.c ****     if (strlen(pin_str) < 2) return 0;
 462:Core/Src/mimic.c ****     
 463:Core/Src/mimic.c ****     // Support "PA4" style by skipping the 'P' prefix if present
 464:Core/Src/mimic.c ****     const char *ptr = pin_str;
 465:Core/Src/mimic.c ****     if ((*ptr == 'P' || *ptr == 'p') && strlen(ptr) >= 3) {
 466:Core/Src/mimic.c ****         ptr++;
 467:Core/Src/mimic.c ****     }
 468:Core/Src/mimic.c ****     
 469:Core/Src/mimic.c ****     *port = Mimic_GetPort(*ptr);
 470:Core/Src/mimic.c ****     if (*port == NULL) return 0;
 471:Core/Src/mimic.c ****     
 472:Core/Src/mimic.c ****     uint8_t pin_num = atoi(ptr + 1);
 473:Core/Src/mimic.c ****     *pin = Mimic_GetPin(pin_num);
 474:Core/Src/mimic.c ****     if (*pin == 0 && pin_str[1] != '0') return 0;
 475:Core/Src/mimic.c ****     
 476:Core/Src/mimic.c ****     return 1;
 477:Core/Src/mimic.c **** }
