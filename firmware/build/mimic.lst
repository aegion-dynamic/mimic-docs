1197:Core/Src/mimic.c **** void Mimic_CMD_UART_TEST(Mimic_Command_t *cmd)
1198:Core/Src/mimic.c **** {
1199:Core/Src/mimic.c ****     if (cmd->argc < 1)
1200:Core/Src/mimic.c ****     {
1201:Core/Src/mimic.c ****         Mimic_SendResponse("Usage: UART_TEST <1|6>\r\n");
1202:Core/Src/mimic.c ****         Mimic_SendResponse("  Requires TX->RX loopback wire!\r\n");
1203:Core/Src/mimic.c ****         return;
1204:Core/Src/mimic.c ****     }
1205:Core/Src/mimic.c ****     
1206:Core/Src/mimic.c ****     UART_HandleTypeDef *huart = Mimic_GetUARTHandle(cmd->args[0]);
1207:Core/Src/mimic.c ****     if (huart == NULL)
1208:Core/Src/mimic.c ****     {
1209:Core/Src/mimic.c ****         Mimic_SendResponse("ERROR: Invalid UART instance\r\n");
1210:Core/Src/mimic.c ****         return;
1211:Core/Src/mimic.c ****     }
1212:Core/Src/mimic.c ****     
1213:Core/Src/mimic.c ****     if (huart->Instance == NULL)
1214:Core/Src/mimic.c ****     {
1215:Core/Src/mimic.c ****         Mimic_SendResponse("ERROR: UART not initialized. Use UART_INIT first.\r\n");
1216:Core/Src/mimic.c ****         return;
1217:Core/Src/mimic.c ****     }
1218:Core/Src/mimic.c ****     
1219:Core/Src/mimic.c ****     const char *test_msg = "MIMIC_LOOPBACK_TEST";
1220:Core/Src/mimic.c ****     uint8_t rx_buf[32] = {0};
1221:Core/Src/mimic.c ****     uint8_t len = strlen(test_msg);
1222:Core/Src/mimic.c ****     
1223:Core/Src/mimic.c ****     Mimic_SendResponseF("Testing UART%s loopback...\r\n", cmd->args[0]);
1224:Core/Src/mimic.c ****     Mimic_SendResponseF("  TX: \"%s\" (%d bytes)\r\n", test_msg, len);
1225:Core/Src/mimic.c ****     
1226:Core/Src/mimic.c ****     /* Send test message */
1227:Core/Src/mimic.c ****     HAL_StatusTypeDef tx_status = HAL_UART_Transmit(huart, (uint8_t*)test_msg, len, 100);
1228:Core/Src/mimic.c ****     if (tx_status != HAL_OK)
1229:Core/Src/mimic.c ****     {
1230:Core/Src/mimic.c ****         Mimic_SendResponse("  TX FAILED!\r\n");
1231:Core/Src/mimic.c ****         return;
1232:Core/Src/mimic.c ****     }
1233:Core/Src/mimic.c ****     
1234:Core/Src/mimic.c ****     /* Receive with timeout */
1235:Core/Src/mimic.c ****     HAL_StatusTypeDef rx_status = HAL_UART_Receive(huart, rx_buf, len, 500);
1236:Core/Src/mimic.c ****     
1237:Core/Src/mimic.c ****     if (rx_status == HAL_OK)
1238:Core/Src/mimic.c ****     {
1239:Core/Src/mimic.c ****         rx_buf[len] = '\0';
1240:Core/Src/mimic.c ****         Mimic_SendResponseF("  RX: \"%s\" (%d bytes)\r\n", rx_buf, len);
1241:Core/Src/mimic.c ****         
1242:Core/Src/mimic.c ****         if (memcmp(test_msg, rx_buf, len) == 0)
1243:Core/Src/mimic.c ****         {
1244:Core/Src/mimic.c ****             Mimic_SendResponse("  RESULT: PASS - Loopback OK!\r\n");
1245:Core/Src/mimic.c ****         }
1246:Core/Src/mimic.c ****         else
1247:Core/Src/mimic.c ****         {
1248:Core/Src/mimic.c ****             Mimic_SendResponse("  RESULT: FAIL - Data mismatch!\r\n");
1249:Core/Src/mimic.c ****         }
1250:Core/Src/mimic.c ****     }
