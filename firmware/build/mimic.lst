1083:Core/Src/mimic.c ****             else
1084:Core/Src/mimic.c ****                 Mimic_SendResponse(".");
1085:Core/Src/mimic.c ****         }
1086:Core/Src/mimic.c ****     }
1087:Core/Src/mimic.c ****     
1088:Core/Src/mimic.c ****     Mimic_SendResponse("\r\n"); // End live line
1089:Core/Src/mimic.c ****     
1090:Core/Src/mimic.c ****     uint32_t elapsed = HAL_GetTick() - start_time;
1091:Core/Src/mimic.c ****     
1092:Core/Src/mimic.c ****     /* Output Final Summary */
