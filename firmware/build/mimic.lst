ARM GAS  /tmp/cchk5ZfX.s 			page 51


 431:Core/Src/mimic.c ****     
 432:Core/Src/mimic.c ****     for (int i = 0; port_map[i].port != NULL; i++)
 433:Core/Src/mimic.c ****     {
 434:Core/Src/mimic.c ****         if (port_map[i].name == upper)
 435:Core/Src/mimic.c ****         {
 436:Core/Src/mimic.c ****             return port_map[i].port;
 437:Core/Src/mimic.c ****         }
