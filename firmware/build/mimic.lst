 481:Core/Src/mimic.c **** /**
 482:Core/Src/mimic.c ****   * @brief  PIN_STATUS <PIN> - Show pin configuration
 483:Core/Src/mimic.c ****   */
 484:Core/Src/mimic.c **** void Mimic_CMD_PIN_STATUS(Mimic_Command_t *cmd)
 485:Core/Src/mimic.c **** {
 486:Core/Src/mimic.c ****     GPIO_TypeDef *port;
 487:Core/Src/mimic.c ****     uint16_t pin;
ARM GAS  /tmp/cc3MLRqL.s 			page 52


 488:Core/Src/mimic.c ****     
 489:Core/Src/mimic.c ****     if (cmd->argc < 1)
 490:Core/Src/mimic.c ****     {
 491:Core/Src/mimic.c ****         Mimic_SendResponse("Usage: PIN_STATUS <PIN> (e.g., PIN_STATUS A5)\r\n");
 492:Core/Src/mimic.c ****         return;
 493:Core/Src/mimic.c ****     }
 494:Core/Src/mimic.c ****     
 495:Core/Src/mimic.c ****     if (!Mimic_ParsePin(cmd->args[0], &port, &pin))
 496:Core/Src/mimic.c ****     {
 497:Core/Src/mimic.c ****         Mimic_SendResponseF("ERROR: Invalid pin '%s'\r\n", cmd->args[0]);
 498:Core/Src/mimic.c ****         return;
 499:Core/Src/mimic.c ****     }
 500:Core/Src/mimic.c ****     
 501:Core/Src/mimic.c ****     uint8_t pin_num = 0;
 502:Core/Src/mimic.c ****     for (int i = 0; i < 16; i++) {
 503:Core/Src/mimic.c ****         if (pin & (1 << i)) { pin_num = i; break; }
 504:Core/Src/mimic.c ****     }
 505:Core/Src/mimic.c ****     
 506:Core/Src/mimic.c ****     /* Read MODER */
 507:Core/Src/mimic.c ****     uint32_t moder = (port->MODER >> (pin_num * 2)) & 0x03;
 508:Core/Src/mimic.c ****     const char *mode_str[] = {"INPUT", "OUTPUT", "ALT_FUNC", "ANALOG"};
 509:Core/Src/mimic.c ****     
 510:Core/Src/mimic.c ****     /* Read OTYPER */
 511:Core/Src/mimic.c ****     uint32_t otyper = (port->OTYPER >> pin_num) & 0x01;
 512:Core/Src/mimic.c ****     const char *otype_str[] = {"PUSH_PULL", "OPEN_DRAIN"};
 513:Core/Src/mimic.c ****     
 514:Core/Src/mimic.c ****     /* Read OSPEEDR */
 515:Core/Src/mimic.c ****     uint32_t ospeedr = (port->OSPEEDR >> (pin_num * 2)) & 0x03;
 516:Core/Src/mimic.c ****     const char *speed_str[] = {"LOW", "MEDIUM", "HIGH", "VERY_HIGH"};
 517:Core/Src/mimic.c ****     
 518:Core/Src/mimic.c ****     /* Read PUPDR */
 519:Core/Src/mimic.c ****     uint32_t pupdr = (port->PUPDR >> (pin_num * 2)) & 0x03;
 520:Core/Src/mimic.c ****     const char *pupd_str[] = {"NONE", "PULL_UP", "PULL_DOWN", "RESERVED"};
 521:Core/Src/mimic.c ****     
 522:Core/Src/mimic.c ****     /* Read current state */
 523:Core/Src/mimic.c ****     uint8_t state = HAL_GPIO_ReadPin(port, pin);
 524:Core/Src/mimic.c ****     
 525:Core/Src/mimic.c ****     Mimic_SendResponseF("PIN %s:\r\n", cmd->args[0]);
 526:Core/Src/mimic.c ****     Mimic_SendResponseF("  Mode:   %s\r\n", mode_str[moder]);
 527:Core/Src/mimic.c ****     Mimic_SendResponseF("  Type:   %s\r\n", otype_str[otyper]);
 528:Core/Src/mimic.c ****     Mimic_SendResponseF("  Speed:  %s\r\n", speed_str[ospeedr]);
 529:Core/Src/mimic.c ****     Mimic_SendResponseF("  Pull:   %s\r\n", pupd_str[pupdr]);
 530:Core/Src/mimic.c ****     Mimic_SendResponseF("  State:  %s\r\n", state ? "HIGH" : "LOW");
 531:Core/Src/mimic.c **** }
