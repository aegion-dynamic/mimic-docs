1106:Core/Src/mimic.c ****     /* Live Polling Strategy:
1107:Core/Src/mimic.c ****        1. Loop until 'length' bytes received OR 'timeout' expires.
1108:Core/Src/mimic.c ****        2. Read byte-by-byte with a short timeout to check for data.
1109:Core/Src/mimic.c ****        3. Echo received characters immediately ("Live Polling").
1110:Core/Src/mimic.c ****        4. Return full/partial buffer at the end.
1111:Core/Src/mimic.c ****     */
1112:Core/Src/mimic.c ****     
1113:Core/Src/mimic.c ****     uint8_t buffer[65] = {0};
1114:Core/Src/mimic.c ****     uint16_t rx_count = 0;
1115:Core/Src/mimic.c ****     uint32_t start_time = HAL_GetTick();
1116:Core/Src/mimic.c ****     
1117:Core/Src/mimic.c ****     Mimic_SendResponse("LIVE: "); // Prefix for live stream
1118:Core/Src/mimic.c ****     
1119:Core/Src/mimic.c ****     while (rx_count < length)
1120:Core/Src/mimic.c ****     {
1121:Core/Src/mimic.c ****         /* Check for total timeout */
1122:Core/Src/mimic.c ****         if ((HAL_GetTick() - start_time) > timeout)
1123:Core/Src/mimic.c ****         {
1124:Core/Src/mimic.c ****             break;
1125:Core/Src/mimic.c ****         }
1126:Core/Src/mimic.c ****         
1127:Core/Src/mimic.c ****         /* Try to read 1 byte with short timeout (10ms) 
1128:Core/Src/mimic.c ****            10ms allows checking 'timeout' frequently enough 
1129:Core/Src/mimic.c ****         */
1130:Core/Src/mimic.c ****         uint8_t byte = 0;
1131:Core/Src/mimic.c ****         if (HAL_UART_Receive(huart, &byte, 1, 10) == HAL_OK)
1132:Core/Src/mimic.c ****         {
1133:Core/Src/mimic.c ****             buffer[rx_count++] = byte;
1134:Core/Src/mimic.c ****             
1135:Core/Src/mimic.c ****             /* Live Echo: Print char if printable, else dot */
1136:Core/Src/mimic.c ****             if (byte >= 32 && byte <= 126)
