 442:Core/Src/mimic.c **** /**
 443:Core/Src/mimic.c ****   * @brief  Get GPIO pin mask from number
 444:Core/Src/mimic.c ****   */
 445:Core/Src/mimic.c **** uint16_t Mimic_GetPin(uint8_t pin_num)
 446:Core/Src/mimic.c **** {
 447:Core/Src/mimic.c ****     if (pin_num > 15) return 0;
 448:Core/Src/mimic.c ****     return (1 << pin_num);
 449:Core/Src/mimic.c **** }
