 164:Core/Src/mimic.c **** /**
 165:Core/Src/mimic.c ****   * @brief  Process incoming commands (call in main loop)
 166:Core/Src/mimic.c ****   */
 167:Core/Src/mimic.c **** void Mimic_Process(void)
 168:Core/Src/mimic.c **** {
 169:Core/Src/mimic.c **** 
 170:Core/Src/mimic.c **** 
 171:Core/Src/mimic.c ****     /* Process all available bytes from interrupt buffer */
 172:Core/Src/mimic.c ****     while (Mimic_RxAvailable())
 173:Core/Src/mimic.c ****     {
 174:Core/Src/mimic.c ****         uint8_t rx = Mimic_RxGet();
 175:Core/Src/mimic.c ****         
 176:Core/Src/mimic.c ****         /* Handle special characters */
 177:Core/Src/mimic.c ****         if (rx == '\r' || rx == '\n')
 178:Core/Src/mimic.c ****         {
 179:Core/Src/mimic.c ****             if (mimic_state.cmd_index > 0)
 180:Core/Src/mimic.c ****             {
 181:Core/Src/mimic.c ****                 Mimic_SendResponse("\r\n");
 182:Core/Src/mimic.c ****                 mimic_state.cmd_buffer[mimic_state.cmd_index] = '\0';
 183:Core/Src/mimic.c ****                 Mimic_ProcessCommand(mimic_state.cmd_buffer);
 184:Core/Src/mimic.c ****                 mimic_state.cmd_index = 0;
 185:Core/Src/mimic.c ****                 Mimic_SendResponse("> ");
 186:Core/Src/mimic.c ****             }
 187:Core/Src/mimic.c ****         }
 188:Core/Src/mimic.c ****         else if (rx == '\b' || rx == 127)  /* Backspace */
 189:Core/Src/mimic.c ****         {
 190:Core/Src/mimic.c ****             if (mimic_state.cmd_index > 0)
 191:Core/Src/mimic.c ****             {
 192:Core/Src/mimic.c ****                 mimic_state.cmd_index--;
 193:Core/Src/mimic.c ****                 Mimic_SendResponse(" \b");  /* Erase character */
 194:Core/Src/mimic.c ****             }
 195:Core/Src/mimic.c ****         }
 196:Core/Src/mimic.c ****         else if (rx >= 32 && rx < 127)  /* Printable */
 197:Core/Src/mimic.c ****         {
 198:Core/Src/mimic.c ****             if (mimic_state.cmd_index < MIMIC_MAX_CMD_LEN - 1)
 199:Core/Src/mimic.c ****             {
 200:Core/Src/mimic.c ****                 mimic_state.cmd_buffer[mimic_state.cmd_index++] = rx;
 201:Core/Src/mimic.c ****             }
 202:Core/Src/mimic.c ****         }
