 239:Core/Src/mimic.c **** uint8_t Mimic_ParseCommand(const char *cmd_line, Mimic_Command_t *cmd)
 240:Core/Src/mimic.c **** {
 241:Core/Src/mimic.c ****     char buffer[MIMIC_MAX_CMD_LEN];
 242:Core/Src/mimic.c ****     char *token;
 243:Core/Src/mimic.c ****     uint8_t idx = 0;
