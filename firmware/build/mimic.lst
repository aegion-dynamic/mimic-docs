1075:Core/Src/mimic.c ****         {
1076:Core/Src/mimic.c ****             buffer[rx_count++] = byte;
1077:Core/Src/mimic.c ****             
1078:Core/Src/mimic.c ****             /* Live Echo: Print char if printable, else dot */
1079:Core/Src/mimic.c ****             if (byte >= 32 && byte <= 126)
1080:Core/Src/mimic.c ****                 Mimic_SendResponseF("%c", byte);
1081:Core/Src/mimic.c ****             else if (byte == '\r' || byte == '\n')
