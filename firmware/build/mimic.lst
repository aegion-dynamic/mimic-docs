 196:Core/Src/mimic.c **** /**
 197:Core/Src/mimic.c ****   * @brief  Parse command line into command structure
 198:Core/Src/mimic.c ****   */
 199:Core/Src/mimic.c **** uint8_t Mimic_ParseCommand(const char *cmd_line, Mimic_Command_t *cmd)
 200:Core/Src/mimic.c **** {
 201:Core/Src/mimic.c ****     char buffer[MIMIC_MAX_CMD_LEN];
 202:Core/Src/mimic.c ****     char *token;
 203:Core/Src/mimic.c ****     uint8_t idx = 0;
 204:Core/Src/mimic.c ****     
 205:Core/Src/mimic.c ****     memset(cmd, 0, sizeof(Mimic_Command_t));
 206:Core/Src/mimic.c ****     strncpy(buffer, cmd_line, MIMIC_MAX_CMD_LEN - 1);
 207:Core/Src/mimic.c ****     
 208:Core/Src/mimic.c ****     /* Get command */
 209:Core/Src/mimic.c ****     token = strtok(buffer, " \t");
 210:Core/Src/mimic.c ****     if (token == NULL) return 0;
 211:Core/Src/mimic.c ****     
 212:Core/Src/mimic.c ****     /* Convert to uppercase */
 213:Core/Src/mimic.c ****     for (int i = 0; token[i]; i++) {
 214:Core/Src/mimic.c ****         cmd->command[i] = (token[i] >= 'a' && token[i] <= 'z') ? token[i] - 32 : token[i];
 215:Core/Src/mimic.c ****     }
 216:Core/Src/mimic.c ****     
 217:Core/Src/mimic.c ****     /* Get arguments */
 218:Core/Src/mimic.c ****     while ((token = strtok(NULL, " \t")) != NULL && idx < MIMIC_MAX_ARGS)
 219:Core/Src/mimic.c ****     {
 220:Core/Src/mimic.c ****         strncpy(cmd->args[idx], token, MIMIC_MAX_ARG_LEN - 1);
 221:Core/Src/mimic.c ****         idx++;
 222:Core/Src/mimic.c ****     }
 223:Core/Src/mimic.c ****     cmd->argc = idx;
 224:Core/Src/mimic.c ****     
 225:Core/Src/mimic.c ****     return 1;
 226:Core/Src/mimic.c **** }
