  93:Core/Src/mimic.c ****             rx_head = next_head;
  94:Core/Src/mimic.c ****         }
  95:Core/Src/mimic.c ****         
  96:Core/Src/mimic.c ****         /* Re-enable interrupt for next byte */
  97:Core/Src/mimic.c ****         HAL_UART_Receive_IT(&MIMIC_HOST_UART, (uint8_t*)&rx_byte, 1);
  98:Core/Src/mimic.c ****     }
