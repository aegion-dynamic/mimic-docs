1096:Core/Src/mimic.c ****         
1097:Core/Src/mimic.c ****         if (rx_count < length)
1098:Core/Src/mimic.c ****              Mimic_SendResponseF("PARTIAL (Time: %lu ms, %d/%d bytes): ", elapsed, rx_count, length
1099:Core/Src/mimic.c ****         else
1100:Core/Src/mimic.c ****              Mimic_SendResponseF("DONE (Time: %lu ms, %d/%d bytes): ", elapsed, rx_count, length);
1101:Core/Src/mimic.c ****              
1102:Core/Src/mimic.c ****         Mimic_SendResponse("DATA: ");
1103:Core/Src/mimic.c ****         Mimic_SendResponse((char*)buffer);
1104:Core/Src/mimic.c ****         Mimic_SendResponse("\r\n");
1105:Core/Src/mimic.c ****         
1106:Core/Src/mimic.c ****         /* Also show hex */
1107:Core/Src/mimic.c ****         Mimic_SendResponse("HEX: ");
1108:Core/Src/mimic.c ****         for (int i = 0; i < rx_count; i++)
