1158:Core/Src/mimic.c ****              
1159:Core/Src/mimic.c ****         Mimic_SendResponse("DATA: ");
1160:Core/Src/mimic.c ****         Mimic_SendResponse((char*)buffer);
1161:Core/Src/mimic.c ****         Mimic_SendResponse("\r\n");
1162:Core/Src/mimic.c ****         
1163:Core/Src/mimic.c ****         /* Also show hex */
1164:Core/Src/mimic.c ****         Mimic_SendResponse("HEX: ");
1165:Core/Src/mimic.c ****         for (int i = 0; i < rx_count; i++)
