 953:Core/Src/mimic.c ****     GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_PP;
 954:Core/Src/mimic.c ****     GPIO_InitStruct.Pull = GPIO_NOPULL;
 955:Core/Src/mimic.c ****     GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
 956:Core/Src/mimic.c ****     HAL_GPIO_Init(port, &GPIO_InitStruct);
 957:Core/Src/mimic.c ****     
 958:Core/Src/mimic.c ****     /* Set to inactive state */
