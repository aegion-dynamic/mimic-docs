1105:Core/Src/mimic.c ****     /* Live Polling Strategy:
1106:Core/Src/mimic.c ****        1. Loop until 'length' bytes received OR 'timeout' expires.
1107:Core/Src/mimic.c ****        2. Read byte-by-byte with a short timeout to check for data.
1108:Core/Src/mimic.c ****        3. Echo received characters immediately ("Live Polling").
1109:Core/Src/mimic.c ****        4. Return full/partial buffer at the end.
1110:Core/Src/mimic.c ****     */
1111:Core/Src/mimic.c ****     
1112:Core/Src/mimic.c ****     uint8_t buffer[65] = {0};
1113:Core/Src/mimic.c ****     uint16_t rx_count = 0;
1114:Core/Src/mimic.c ****     uint32_t start_time = HAL_GetTick();
1115:Core/Src/mimic.c ****     
1116:Core/Src/mimic.c ****     Mimic_SendResponse("LIVE: "); // Prefix for live stream
1117:Core/Src/mimic.c ****     
1118:Core/Src/mimic.c ****     while (rx_count < length)
1119:Core/Src/mimic.c ****     {
1120:Core/Src/mimic.c ****         /* Check for total timeout */
1121:Core/Src/mimic.c ****         if ((HAL_GetTick() - start_time) > timeout)
1122:Core/Src/mimic.c ****         {
1123:Core/Src/mimic.c ****             break;
1124:Core/Src/mimic.c ****         }
1125:Core/Src/mimic.c ****         
1126:Core/Src/mimic.c ****         /* Try to read 1 byte with short timeout (10ms) 
1127:Core/Src/mimic.c ****            10ms allows checking 'timeout' frequently enough 
1128:Core/Src/mimic.c ****         */
1129:Core/Src/mimic.c ****         uint8_t byte = 0;
1130:Core/Src/mimic.c ****         if (HAL_UART_Receive(huart, &byte, 1, 10) == HAL_OK)
1131:Core/Src/mimic.c ****         {
1132:Core/Src/mimic.c ****             buffer[rx_count++] = byte;
1133:Core/Src/mimic.c ****             
1134:Core/Src/mimic.c ****             /* Live Echo: Print char if printable, else dot */
1135:Core/Src/mimic.c ****             if (byte >= 32 && byte <= 126)
1136:Core/Src/mimic.c ****                 Mimic_SendResponseF("%c", byte);
ARM GAS  /tmp/cc3MLRqL.s 			page 68


1137:Core/Src/mimic.c ****             else if (byte == '\r' || byte == '\n')
1138:Core/Src/mimic.c ****                  Mimic_SendResponseF("%c", byte); // Pass newlines
1139:Core/Src/mimic.c ****             else
1140:Core/Src/mimic.c ****                 Mimic_SendResponse(".");
1141:Core/Src/mimic.c ****         }
1142:Core/Src/mimic.c ****     }
1143:Core/Src/mimic.c ****     
1144:Core/Src/mimic.c ****     Mimic_SendResponse("\r\n"); // End live line
1145:Core/Src/mimic.c ****     
1146:Core/Src/mimic.c ****     uint32_t elapsed = HAL_GetTick() - start_time;
1147:Core/Src/mimic.c ****     
1148:Core/Src/mimic.c ****     /* Output Final Summary */
1149:Core/Src/mimic.c ****     if (rx_count > 0)
1150:Core/Src/mimic.c ****     {
1151:Core/Src/mimic.c ****         buffer[rx_count] = '\0';
1152:Core/Src/mimic.c ****         
1153:Core/Src/mimic.c ****         if (rx_count < length)
1154:Core/Src/mimic.c ****              Mimic_SendResponseF("PARTIAL (Time: %lu ms, %d/%d bytes): ", elapsed, rx_count, length
1155:Core/Src/mimic.c ****         else
1156:Core/Src/mimic.c ****              Mimic_SendResponseF("DONE (Time: %lu ms, %d/%d bytes): ", elapsed, rx_count, length);
1157:Core/Src/mimic.c ****              
1158:Core/Src/mimic.c ****         Mimic_SendResponse("DATA: ");
1159:Core/Src/mimic.c ****         Mimic_SendResponse((char*)buffer);
1160:Core/Src/mimic.c ****         Mimic_SendResponse("\r\n");
1161:Core/Src/mimic.c ****         
1162:Core/Src/mimic.c ****         /* Also show hex */
1163:Core/Src/mimic.c ****         Mimic_SendResponse("HEX: ");
1164:Core/Src/mimic.c ****         for (int i = 0; i < rx_count; i++)
1165:Core/Src/mimic.c ****         {
1166:Core/Src/mimic.c ****             Mimic_SendResponseF("%02X ", buffer[i]);
1167:Core/Src/mimic.c ****         }
1168:Core/Src/mimic.c ****         Mimic_SendResponse("\r\n");
1169:Core/Src/mimic.c ****     }
1170:Core/Src/mimic.c ****     else
1171:Core/Src/mimic.c ****     {
1172:Core/Src/mimic.c ****         Mimic_SendResponse("TIMEOUT: No data received\r\n");
1173:Core/Src/mimic.c ****     }
1174:Core/Src/mimic.c **** }
