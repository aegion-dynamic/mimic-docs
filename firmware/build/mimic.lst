 259:Core/Src/mimic.c ****     {
ARM GAS  /tmp/cc3MLRqL.s 			page 48


 260:Core/Src/mimic.c ****         strncpy(cmd->args[idx], token, MIMIC_MAX_ARG_LEN - 1);
 261:Core/Src/mimic.c ****         idx++;
