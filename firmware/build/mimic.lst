 234:Core/Src/mimic.c **** uint8_t Mimic_ParseCommand(const char *cmd_line, Mimic_Command_t *cmd)
 235:Core/Src/mimic.c **** {
 236:Core/Src/mimic.c ****     char buffer[MIMIC_MAX_CMD_LEN];
 237:Core/Src/mimic.c ****     char *token;
 238:Core/Src/mimic.c ****     uint8_t idx = 0;
 239:Core/Src/mimic.c ****     
 240:Core/Src/mimic.c ****     memset(cmd, 0, sizeof(Mimic_Command_t));
 241:Core/Src/mimic.c ****     strncpy(buffer, cmd_line, MIMIC_MAX_CMD_LEN - 1);
 242:Core/Src/mimic.c ****     
 243:Core/Src/mimic.c ****     /* Get command */
 244:Core/Src/mimic.c ****     token = strtok(buffer, " \t");
 245:Core/Src/mimic.c ****     if (token == NULL) return 0;
 246:Core/Src/mimic.c ****     
 247:Core/Src/mimic.c ****     /* Convert to uppercase */
 248:Core/Src/mimic.c ****     for (int i = 0; token[i]; i++) {
 249:Core/Src/mimic.c ****         cmd->command[i] = (token[i] >= 'a' && token[i] <= 'z') ? token[i] - 32 : token[i];
 250:Core/Src/mimic.c ****     }
 251:Core/Src/mimic.c ****     
 252:Core/Src/mimic.c ****     /* Get arguments */
 253:Core/Src/mimic.c ****     while ((token = strtok(NULL, " \t")) != NULL && idx < MIMIC_MAX_ARGS)
 254:Core/Src/mimic.c ****     {
 255:Core/Src/mimic.c ****         strncpy(cmd->args[idx], token, MIMIC_MAX_ARG_LEN - 1);
 256:Core/Src/mimic.c ****         idx++;
 257:Core/Src/mimic.c ****     }
 258:Core/Src/mimic.c ****     cmd->argc = idx;
 259:Core/Src/mimic.c ****     
ARM GAS  /tmp/cchk5ZfX.s 			page 48


 260:Core/Src/mimic.c ****     return 1;
 261:Core/Src/mimic.c **** }
