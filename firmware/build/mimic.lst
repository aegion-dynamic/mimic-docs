 451:Core/Src/mimic.c **** /**
 452:Core/Src/mimic.c ****   * @brief  Parse pin string like "A5" or "D12"
 453:Core/Src/mimic.c ****   */
 454:Core/Src/mimic.c **** uint8_t Mimic_ParsePin(const char *pin_str, GPIO_TypeDef **port, uint16_t *pin)
 455:Core/Src/mimic.c **** {
 456:Core/Src/mimic.c ****     if (strlen(pin_str) < 2) return 0;
 457:Core/Src/mimic.c ****     
 458:Core/Src/mimic.c ****     // Support "PA4" style by skipping the 'P' prefix if present
 459:Core/Src/mimic.c ****     const char *ptr = pin_str;
 460:Core/Src/mimic.c ****     if ((*ptr == 'P' || *ptr == 'p') && strlen(ptr) >= 3) {
 461:Core/Src/mimic.c ****         ptr++;
 462:Core/Src/mimic.c ****     }
 463:Core/Src/mimic.c ****     
 464:Core/Src/mimic.c ****     *port = Mimic_GetPort(*ptr);
 465:Core/Src/mimic.c ****     if (*port == NULL) return 0;
 466:Core/Src/mimic.c ****     
 467:Core/Src/mimic.c ****     uint8_t pin_num = atoi(ptr + 1);
 468:Core/Src/mimic.c ****     *pin = Mimic_GetPin(pin_num);
 469:Core/Src/mimic.c ****     if (*pin == 0 && pin_str[1] != '0') return 0;
 470:Core/Src/mimic.c ****     
 471:Core/Src/mimic.c ****     return 1;
 472:Core/Src/mimic.c **** }
