 476:Core/Src/mimic.c **** /**
 477:Core/Src/mimic.c ****   * @brief  PIN_STATUS <PIN> - Show pin configuration
 478:Core/Src/mimic.c ****   */
 479:Core/Src/mimic.c **** void Mimic_CMD_PIN_STATUS(Mimic_Command_t *cmd)
 480:Core/Src/mimic.c **** {
 481:Core/Src/mimic.c ****     GPIO_TypeDef *port;
 482:Core/Src/mimic.c ****     uint16_t pin;
 483:Core/Src/mimic.c ****     
 484:Core/Src/mimic.c ****     if (cmd->argc < 1)
 485:Core/Src/mimic.c ****     {
 486:Core/Src/mimic.c ****         Mimic_SendResponse("Usage: PIN_STATUS <PIN> (e.g., PIN_STATUS A5)\r\n");
 487:Core/Src/mimic.c ****         return;
ARM GAS  /tmp/cchk5ZfX.s 			page 52


 488:Core/Src/mimic.c ****     }
 489:Core/Src/mimic.c ****     
 490:Core/Src/mimic.c ****     if (!Mimic_ParsePin(cmd->args[0], &port, &pin))
 491:Core/Src/mimic.c ****     {
 492:Core/Src/mimic.c ****         Mimic_SendResponseF("ERROR: Invalid pin '%s'\r\n", cmd->args[0]);
 493:Core/Src/mimic.c ****         return;
 494:Core/Src/mimic.c ****     }
 495:Core/Src/mimic.c ****     
 496:Core/Src/mimic.c ****     uint8_t pin_num = 0;
 497:Core/Src/mimic.c ****     for (int i = 0; i < 16; i++) {
 498:Core/Src/mimic.c ****         if (pin & (1 << i)) { pin_num = i; break; }
 499:Core/Src/mimic.c ****     }
 500:Core/Src/mimic.c ****     
 501:Core/Src/mimic.c ****     /* Read MODER */
 502:Core/Src/mimic.c ****     uint32_t moder = (port->MODER >> (pin_num * 2)) & 0x03;
 503:Core/Src/mimic.c ****     const char *mode_str[] = {"INPUT", "OUTPUT", "ALT_FUNC", "ANALOG"};
 504:Core/Src/mimic.c ****     
 505:Core/Src/mimic.c ****     /* Read OTYPER */
 506:Core/Src/mimic.c ****     uint32_t otyper = (port->OTYPER >> pin_num) & 0x01;
 507:Core/Src/mimic.c ****     const char *otype_str[] = {"PUSH_PULL", "OPEN_DRAIN"};
 508:Core/Src/mimic.c ****     
 509:Core/Src/mimic.c ****     /* Read OSPEEDR */
 510:Core/Src/mimic.c ****     uint32_t ospeedr = (port->OSPEEDR >> (pin_num * 2)) & 0x03;
 511:Core/Src/mimic.c ****     const char *speed_str[] = {"LOW", "MEDIUM", "HIGH", "VERY_HIGH"};
 512:Core/Src/mimic.c ****     
 513:Core/Src/mimic.c ****     /* Read PUPDR */
 514:Core/Src/mimic.c ****     uint32_t pupdr = (port->PUPDR >> (pin_num * 2)) & 0x03;
 515:Core/Src/mimic.c ****     const char *pupd_str[] = {"NONE", "PULL_UP", "PULL_DOWN", "RESERVED"};
 516:Core/Src/mimic.c ****     
 517:Core/Src/mimic.c ****     /* Read current state */
 518:Core/Src/mimic.c ****     uint8_t state = HAL_GPIO_ReadPin(port, pin);
 519:Core/Src/mimic.c ****     
 520:Core/Src/mimic.c ****     Mimic_SendResponseF("PIN %s:\r\n", cmd->args[0]);
 521:Core/Src/mimic.c ****     Mimic_SendResponseF("  Mode:   %s\r\n", mode_str[moder]);
 522:Core/Src/mimic.c ****     Mimic_SendResponseF("  Type:   %s\r\n", otype_str[otyper]);
 523:Core/Src/mimic.c ****     Mimic_SendResponseF("  Speed:  %s\r\n", speed_str[ospeedr]);
 524:Core/Src/mimic.c ****     Mimic_SendResponseF("  Pull:   %s\r\n", pupd_str[pupdr]);
 525:Core/Src/mimic.c ****     Mimic_SendResponseF("  State:  %s\r\n", state ? "HIGH" : "LOW");
 526:Core/Src/mimic.c **** }
