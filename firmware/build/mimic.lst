 130:Core/Src/mimic.c **** /**
 131:Core/Src/mimic.c ****   * @brief  Process incoming commands (call in main loop)
 132:Core/Src/mimic.c ****   */
 133:Core/Src/mimic.c **** void Mimic_Process(void)
 134:Core/Src/mimic.c **** {
 135:Core/Src/mimic.c ****     /* Process all available bytes from interrupt buffer */
 136:Core/Src/mimic.c ****     while (Mimic_RxAvailable())
 137:Core/Src/mimic.c ****     {
 138:Core/Src/mimic.c ****         uint8_t rx = Mimic_RxGet();
 139:Core/Src/mimic.c ****         
 140:Core/Src/mimic.c ****         /* Echo back */
 141:Core/Src/mimic.c ****         HAL_UART_Transmit(&MIMIC_HOST_UART, &rx, 1, 10);
 142:Core/Src/mimic.c ****         
 143:Core/Src/mimic.c ****         /* Handle special characters */
 144:Core/Src/mimic.c ****         if (rx == '\r' || rx == '\n')
 145:Core/Src/mimic.c ****         {
 146:Core/Src/mimic.c ****             if (mimic_state.cmd_index > 0)
 147:Core/Src/mimic.c ****             {
 148:Core/Src/mimic.c ****                 Mimic_SendResponse("\r\n");
 149:Core/Src/mimic.c ****                 mimic_state.cmd_buffer[mimic_state.cmd_index] = '\0';
 150:Core/Src/mimic.c ****                 Mimic_ProcessCommand(mimic_state.cmd_buffer);
 151:Core/Src/mimic.c ****                 mimic_state.cmd_index = 0;
 152:Core/Src/mimic.c ****                 Mimic_SendResponse("> ");
 153:Core/Src/mimic.c ****             }
 154:Core/Src/mimic.c ****         }
 155:Core/Src/mimic.c ****         else if (rx == '\b' || rx == 127)  /* Backspace */
 156:Core/Src/mimic.c ****         {
 157:Core/Src/mimic.c ****             if (mimic_state.cmd_index > 0)
 158:Core/Src/mimic.c ****             {
 159:Core/Src/mimic.c ****                 mimic_state.cmd_index--;
 160:Core/Src/mimic.c ****                 Mimic_SendResponse(" \b");  /* Erase character */
 161:Core/Src/mimic.c ****             }
 162:Core/Src/mimic.c ****         }
 163:Core/Src/mimic.c ****         else if (rx >= 32 && rx < 127)  /* Printable */
 164:Core/Src/mimic.c ****         {
 165:Core/Src/mimic.c ****             if (mimic_state.cmd_index < MIMIC_MAX_CMD_LEN - 1)
 166:Core/Src/mimic.c ****             {
 167:Core/Src/mimic.c ****                 mimic_state.cmd_buffer[mimic_state.cmd_index++] = rx;
 168:Core/Src/mimic.c ****             }
 169:Core/Src/mimic.c ****         }
 170:Core/Src/mimic.c ****     }
 171:Core/Src/mimic.c **** }
