 164:Core/Src/mimic.c **** /**
 165:Core/Src/mimic.c ****   * @brief  Process incoming commands (call in main loop)
 166:Core/Src/mimic.c ****   */
 167:Core/Src/mimic.c **** void Mimic_Process(void)
 168:Core/Src/mimic.c **** {
 169:Core/Src/mimic.c ****     // HEARTBEAT: Simple blink
 170:Core/Src/mimic.c ****     static uint32_t last_blink = 0;
 171:Core/Src/mimic.c ****     if (HAL_GetTick() - last_blink > 500) {
 172:Core/Src/mimic.c ****         HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
 173:Core/Src/mimic.c ****         last_blink = HAL_GetTick();
 174:Core/Src/mimic.c ****     }
 175:Core/Src/mimic.c **** 
 176:Core/Src/mimic.c ****     /* Process all available bytes from interrupt buffer */
 177:Core/Src/mimic.c ****     while (Mimic_RxAvailable())
 178:Core/Src/mimic.c ****     {
 179:Core/Src/mimic.c ****         uint8_t rx = Mimic_RxGet();
 180:Core/Src/mimic.c ****         
 181:Core/Src/mimic.c ****         /* Handle special characters */
 182:Core/Src/mimic.c ****         if (rx == '\r' || rx == '\n')
 183:Core/Src/mimic.c ****         {
 184:Core/Src/mimic.c ****             if (mimic_state.cmd_index > 0)
 185:Core/Src/mimic.c ****             {
 186:Core/Src/mimic.c ****                 Mimic_SendResponse("\r\n");
 187:Core/Src/mimic.c ****                 mimic_state.cmd_buffer[mimic_state.cmd_index] = '\0';
 188:Core/Src/mimic.c ****                 Mimic_ProcessCommand(mimic_state.cmd_buffer);
 189:Core/Src/mimic.c ****                 mimic_state.cmd_index = 0;
 190:Core/Src/mimic.c ****                 Mimic_SendResponse("> ");
 191:Core/Src/mimic.c ****             }
 192:Core/Src/mimic.c ****         }
 193:Core/Src/mimic.c ****         else if (rx == '\b' || rx == 127)  /* Backspace */
 194:Core/Src/mimic.c ****         {
 195:Core/Src/mimic.c ****             if (mimic_state.cmd_index > 0)
 196:Core/Src/mimic.c ****             {
 197:Core/Src/mimic.c ****                 mimic_state.cmd_index--;
 198:Core/Src/mimic.c ****                 Mimic_SendResponse(" \b");  /* Erase character */
 199:Core/Src/mimic.c ****             }
 200:Core/Src/mimic.c ****         }
 201:Core/Src/mimic.c ****         else if (rx >= 32 && rx < 127)  /* Printable */
 202:Core/Src/mimic.c ****         {
ARM GAS  /tmp/cc3MLRqL.s 			page 47


 203:Core/Src/mimic.c ****             if (mimic_state.cmd_index < MIMIC_MAX_CMD_LEN - 1)
 204:Core/Src/mimic.c ****             {
 205:Core/Src/mimic.c ****                 mimic_state.cmd_buffer[mimic_state.cmd_index++] = rx;
 206:Core/Src/mimic.c ****             }
 207:Core/Src/mimic.c ****         }
 208:Core/Src/mimic.c ****     }
 209:Core/Src/mimic.c ****     
 210:Core/Src/mimic.c ****     Mimic_SPI_Sync();
 211:Core/Src/mimic.c **** }
