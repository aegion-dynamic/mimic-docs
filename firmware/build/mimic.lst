 425:Core/Src/mimic.c **** /**
 426:Core/Src/mimic.c ****   * @brief  PIN_STATUS <PIN> - Show pin configuration
 427:Core/Src/mimic.c ****   */
 428:Core/Src/mimic.c **** void Mimic_CMD_PIN_STATUS(Mimic_Command_t *cmd)
 429:Core/Src/mimic.c **** {
 430:Core/Src/mimic.c ****     GPIO_TypeDef *port;
 431:Core/Src/mimic.c ****     uint16_t pin;
 432:Core/Src/mimic.c ****     
 433:Core/Src/mimic.c ****     if (cmd->argc < 1)
 434:Core/Src/mimic.c ****     {
 435:Core/Src/mimic.c ****         Mimic_SendResponse("Usage: PIN_STATUS <PIN> (e.g., PIN_STATUS A5)\r\n");
 436:Core/Src/mimic.c ****         return;
 437:Core/Src/mimic.c ****     }
 438:Core/Src/mimic.c ****     
 439:Core/Src/mimic.c ****     if (!Mimic_ParsePin(cmd->args[0], &port, &pin))
 440:Core/Src/mimic.c ****     {
 441:Core/Src/mimic.c ****         Mimic_SendResponseF("ERROR: Invalid pin '%s'\r\n", cmd->args[0]);
 442:Core/Src/mimic.c ****         return;
 443:Core/Src/mimic.c ****     }
 444:Core/Src/mimic.c ****     
 445:Core/Src/mimic.c ****     uint8_t pin_num = 0;
 446:Core/Src/mimic.c ****     for (int i = 0; i < 16; i++) {
 447:Core/Src/mimic.c ****         if (pin & (1 << i)) { pin_num = i; break; }
 448:Core/Src/mimic.c ****     }
 449:Core/Src/mimic.c ****     
 450:Core/Src/mimic.c ****     /* Read MODER */
 451:Core/Src/mimic.c ****     uint32_t moder = (port->MODER >> (pin_num * 2)) & 0x03;
 452:Core/Src/mimic.c ****     const char *mode_str[] = {"INPUT", "OUTPUT", "ALT_FUNC", "ANALOG"};
 453:Core/Src/mimic.c ****     
 454:Core/Src/mimic.c ****     /* Read OTYPER */
 455:Core/Src/mimic.c ****     uint32_t otyper = (port->OTYPER >> pin_num) & 0x01;
 456:Core/Src/mimic.c ****     const char *otype_str[] = {"PUSH_PULL", "OPEN_DRAIN"};
 457:Core/Src/mimic.c ****     
 458:Core/Src/mimic.c ****     /* Read OSPEEDR */
 459:Core/Src/mimic.c ****     uint32_t ospeedr = (port->OSPEEDR >> (pin_num * 2)) & 0x03;
 460:Core/Src/mimic.c ****     const char *speed_str[] = {"LOW", "MEDIUM", "HIGH", "VERY_HIGH"};
 461:Core/Src/mimic.c ****     
 462:Core/Src/mimic.c ****     /* Read PUPDR */
 463:Core/Src/mimic.c ****     uint32_t pupdr = (port->PUPDR >> (pin_num * 2)) & 0x03;
 464:Core/Src/mimic.c ****     const char *pupd_str[] = {"NONE", "PULL_UP", "PULL_DOWN", "RESERVED"};
ARM GAS  /tmp/ccLC7bCB.s 			page 52


 465:Core/Src/mimic.c ****     
 466:Core/Src/mimic.c ****     /* Read current state */
 467:Core/Src/mimic.c ****     uint8_t state = HAL_GPIO_ReadPin(port, pin);
 468:Core/Src/mimic.c ****     
 469:Core/Src/mimic.c ****     Mimic_SendResponseF("PIN %s:\r\n", cmd->args[0]);
 470:Core/Src/mimic.c ****     Mimic_SendResponseF("  Mode:   %s\r\n", mode_str[moder]);
 471:Core/Src/mimic.c ****     Mimic_SendResponseF("  Type:   %s\r\n", otype_str[otyper]);
 472:Core/Src/mimic.c ****     Mimic_SendResponseF("  Speed:  %s\r\n", speed_str[ospeedr]);
 473:Core/Src/mimic.c ****     Mimic_SendResponseF("  Pull:   %s\r\n", pupd_str[pupdr]);
 474:Core/Src/mimic.c ****     Mimic_SendResponseF("  State:  %s\r\n", state ? "HIGH" : "LOW");
 475:Core/Src/mimic.c **** }
 476:Core/Src/mimic.c **** 
